# --- required ---
DISCORD_TOKEN=your-bot-token            # Dev Portal → Bot → Token. Keep secret.

# --- dashboard (optional — bot works without it) ---
CLIENT_ID=                              # Dev Portal → OAuth2 → Client ID
CLIENT_SECRET=                          # Dev Portal → OAuth2 → Client Secret
PUBLIC_URL=https://madhoney.example.com # where the dashboard is reachable
PORT=8300                               # local port the dashboard binds (127.0.0.1)

# --- optional ---
# Copy spam text into the log-channel ban report. Requires the privileged
# "Message Content" intent to be enabled in the Dev Portal FIRST, or login fails.
MESSAGE_CONTENT=off

# Self-hosting? Set this to true to unlock the option to hide the small
# "protected by MadHoney" credit line on honeypot banners. On the official
# hosted service the credit stays on. Leave unset if you're not self-hosting.
SELF_HOSTED=true
